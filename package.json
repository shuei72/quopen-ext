{
  "name": "quopen",
  "displayName": "Quopen",
  "description": "Recursive Quick Open for VS Code that helps you narrow by folder before opening a file.",
  "version": "0.0.1",
  "publisher": "shuei",
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1f2933",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shuei72/quopen-ext.git"
  },
  "homepage": "https://github.com/shuei72/quopen-ext#readme",
  "bugs": {
    "url": "https://github.com/shuei72/quopen-ext/issues"
  },
  "engines": {
    "vscode": "^1.108.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "quick open",
    "quickpick",
    "open file",
    "file picker",
    "folder",
    "file",
    "navigation",
    "workspace",
    "search",
    "open"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": {
      "supported": true
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "quopen.open",
        "title": "Browse Workspace",
        "category": "Quopen"
      },
      {
        "command": "quopen.openFromActiveFile",
        "title": "Start from File",
        "category": "Quopen"
      }
    ],
    "keybindings": [
      {
        "command": "quopen.browser.deleteWordLeft",
        "key": "ctrl+w",
        "when": "quopen.browserVisible && inQuickInput && quickInputType == 'quickPick'"
      },
      {
        "command": "quopen.browser.deleteWordLeft",
        "key": "ctrl+backspace",
        "when": "quopen.browserVisible && inQuickInput && quickInputType == 'quickPick'"
      },
      {
        "command": "quopen.browser.deleteCharacterLeft",
        "key": "ctrl+h",
        "when": "quopen.browserVisible && inQuickInput && quickInputType == 'quickPick'"
      },
      {
        "command": "quopen.browser.narrowSelection",
        "key": "tab",
        "when": "quopen.browserVisible && inQuickInput && quickInputType == 'quickPick'"
      },
      {
        "command": "quopen.browser.up",
        "key": "ctrl+u",
        "when": "quopen.browserVisible && inQuickInput && quickInputType == 'quickPick'"
      },
      {
        "command": "workbench.action.quickOpenNavigateNextInFilePicker",
        "key": "ctrl+n",
        "when": "quopen.browserVisible && inQuickInput && quickInputType == 'quickPick'"
      },
      {
        "command": "workbench.action.quickOpenNavigatePreviousInFilePicker",
        "key": "ctrl+p",
        "when": "quopen.browserVisible && inQuickInput && quickInputType == 'quickPick'"
      }
    ],
    "configuration": {
      "title": "Quopen",
      "properties": {
        "quopen.searchBackend": {
          "type": "string",
          "enum": [
            "auto",
            "everything",
            "native"
          ],
          "default": "auto",
          "markdownDescription": "Selects the search backend. `auto` prefers Everything on Windows and falls back to the native workspace index."
        },
        "quopen.everythingPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional absolute path to `es.exe` when using the Everything backend."
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.108.0",
    "typescript": "^5.4.5"
  }
}
